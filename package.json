'use client';

import { useEffect, useRef, useState } from 'react';

const CONTENT = {
  en: {
    nav: ['About Us'],
    connect: '+ Connect',
    heroText: 'AIKRON',
    tagLeft: ['In the dark', 'is where', 'light takes form'],
    tagRight: ['Creativity powered', 'by artificial', 'intelligence'],
    credit: 'Art & Design by AIKRON',
    aboutTitle: 'About Us',
    aboutText:
      'We are creative developers and digital artists based in Slovenia. We work at the intersection of code, sound, and visual art — building immersive experiences that challenge the boundary between human and machine creativity. Every project begins with a question.',
    skills: [
      'Creative Direction',
      'Motion Design',
      'Web Development',
      'Sound Design',
      'AI Art Direction',
      'Brand Identity',
    ],
    contactTitle: "Let's Talk",
    contactText: 'Available for selected projects and collaborations.',
    contactBtn: 'Get in touch',
    copyright: '© 2024 All rights reserved',
  },
  slo: {
    nav: ['O nas'],
    connect: '+ Poveži se',
    heroText: 'AIKRON',
    tagLeft: ['V temi', 'se rodi', 'svetloba'],
    tagRight: ['Kreativnost', 'podprta z', 'umetno inteligenco'],
    credit: 'Umetnost & Dizajn by AIKRON',
    aboutTitle: 'O nas',
    aboutText:
      'Smo kreativni razvijalci in digitalni umetniki s sedežem v Sloveniji. Delamo na stičišču kode, zvoka in vizualne umetnosti — ustvarjamo poglobljene izkušnje, ki izzivajo mejo med človeško in strojno ustvarjalnostjo. Vsak projekt se začne z vprašanjem.',
    skills: [
      'Kreativna Direkcija',
      'Motion Dizajn',
      'Spletni Razvoj',
      'Oblikovanje Zvoka',
      'AI Umetniška Direkcija',
      'Vizualna Identiteta',
    ],
    contactTitle: 'Pogovorimo se',
    contactText: 'Na voljo za izbrane projekte in sodelovanja.',
    contactBtn: 'Stopite v stik',
    copyright: '© 2024 Vse pravice pridržane',
  },
};

const LINKS = [
  { label: 'Tik Tok', url: 'https://www.tiktok.com/@ariasmith20x?_r=1&_t=ZN-961sC2e19iI' },
  { label: 'Instagram', url: 'https://www.instagram.com/ariasmith20x?igsh=ZHA5aXhhYzV2Y2Y3' },
  { label: 'Twitter', url: null },
];

export default function Home() {
  const [lang, setLang] = useState<'en' | 'slo'>('en');
  const [heroVisible, setHeroVisible] = useState(true);
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const grainRef = useRef<HTMLCanvasElement>(null);
  const heroRef = useRef<HTMLDivElement>(null);
  const rafRef = useRef<number>(0);

  const t = CONTENT[lang];

  useEffect(() => {
    const canvas = canvasRef.current;
    const grain = grainRef.current;
    if (!canvas || !grain) return;
    const ctx = canvas.getContext('2d')!;
    const gCtx = grain.getContext('2d')!;

    const density = ' .:-=+*#%@';
    let rotation = 0, atmoPhase = 0, glitch = 0, lastGlitch = 0, time = 0;

    function resize() {
      const hero = heroRef.current;
      if (!hero) return;
      canvas!.width = grain!.width = hero.offsetWidth;
      canvas!.height = grain!.height = hero.offsetHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    function draw() {
      time += 0.016; rotation += 0.005; atmoPhase += 0.016 / 6;
      const atmo = (Math.sin(atmoPhase * Math.PI) + 1) / 2;
      if (time - lastGlitch > 2.5 + Math.random() * 4) {
        glitch = Math.random() > 0.4 ? Math.random() : 0;
        lastGlitch = time;
      }
      glitch *= 0.94;

      const W = canvas!.width, H = canvas!.height;
      if (!W || !H) { rafRef.current = requestAnimationFrame(draw); return; }
      const cx = W / 2, cy = H / 2, R = Math.min(W, H) * 0.2;
      const hue = 180 + atmo * 60;

      ctx.fillStyle = '#000'; ctx.fillRect(0, 0, W, H);
      const bg = ctx.createRadialGradient(cx, cy - 50, 0, cx, cy, Math.max(W, H) * 0.8);
      bg.addColorStop(0, `hsla(${hue + 40},80%,60%,.4)`);
      bg.addColorStop(0.3, `hsla(${hue},60%,40%,.3)`);
      bg.addColorStop(0.6, `hsla(${hue - 20},40%,20%,.2)`);
      bg.addColorStop(1, 'rgba(0,0,0,.9)');
      ctx.fillStyle = bg; ctx.fillRect(0, 0, W, H);

      ctx.save();
      const sg = Math.random() < 0.08 && glitch > 0.4;
      if (sg) ctx.translate((Math.random() - 0.5) * 20 * glitch, (Math.random() - 0.5) * 14 * glitch);

      const og = ctx.createRadialGradient(cx, cy, 0, cx, cy, R * 1.5);
      og.addColorStop(0, `hsla(${hue + 10},100%,95%,.9)`);
      og.addColorStop(0.2, `hsla(${hue + 20},90%,80%,.7)`);
      og.addColorStop(0.5, `hsla(${hue},70%,50%,.4)`);
      og.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = og; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = `hsla(${hue + 20},100%,95%,.8)`;
      ctx.beginPath(); ctx.arc(cx, cy, R * 0.3, 0, Math.PI * 2); ctx.fill();

      if (sg) {
        ctx.globalCompositeOperation = 'screen';
        ctx.fillStyle = `hsla(100,100%,50%,${0.5 * glitch})`;
        ctx.beginPath(); ctx.arc(cx + glitch * 8, cy, R * 0.3, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = `hsla(240,100%,50%,${0.4 * glitch})`;
        ctx.beginPath(); ctx.arc(cx - glitch * 8, cy, R * 0.3, 0, Math.PI * 2); ctx.fill();
        ctx.globalCompositeOperation = 'source-over';
        ctx.strokeStyle = `rgba(255,255,255,${0.5 * glitch})`; ctx.lineWidth = 1;
        for (let i = 0; i < 4; i++) {
          const y = cy - R + Math.random() * R * 2;
          ctx.beginPath(); ctx.moveTo(cx - R, y); ctx.lineTo(cx + R, y); ctx.stroke();
        }
      }

      ctx.strokeStyle = `hsla(${hue + 20},80%,70%,.5)`; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.arc(cx, cy, R * 1.2, 0, Math.PI * 2); ctx.stroke();
      ctx.restore();

      ctx.font = '10px monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      const sp = 9, cols = Math.floor(W / sp), rows = Math.floor(H / sp);
      for (let i = 0; i < Math.min(cols, 160); i++) {
        for (let j = 0; j < Math.min(rows, 100); j++) {
          const x = (i - cols / 2) * sp + cx, y = (j - rows / 2) * sp + cy;
          const dx = x - cx, dy = y - cy, d = Math.sqrt(dx * dx + dy * dy);
          if (d < R && Math.random() > 0.4) {
            const z = Math.sqrt(Math.max(0, R * R - dx * dx - dy * dy));
            const rz = dx * Math.sin(rotation) + z * Math.cos(rotation);
            const br = (rz + R) / (R * 2);
            if (rz > -R * 0.3) {
              let ch = density[Math.floor(br * (density.length - 1))];
              if (d < R * 0.8 && glitch > 0.8 && Math.random() < 0.3) ch = '█▓▒░▄▀'[Math.floor(Math.random() * 6)];
              ctx.fillStyle = `rgba(255,255,255,${Math.max(0.15, br)})`; ctx.fillText(ch, x, y);
            }
          }
        }
      }

      gCtx.clearRect(0, 0, W, H);
      const gi = gCtx.createImageData(W, H), gd = gi.data;
      const gi_i = 0.22 + Math.sin(time * 10) * 0.03;
      for (let i = 0; i < gd.length; i += 4) {
        const g = (Math.random() - 0.5) * gi_i * 255;
        gd[i] = gd[i + 1] = gd[i + 2] = Math.max(0, Math.min(255, 128 + g));
        gd[i + 3] = Math.abs(g) * 3;
      }
      gCtx.putImageData(gi, 0, 0);
      rafRef.current = requestAnimationFrame(draw);
    }

    draw();
    return () => {
      cancelAnimationFrame(rafRef.current);
      window.removeEventListener('resize', resize);
    };
  }, []);

  return (
    <main className="bg-black text-white min-h-screen font-sans">
      {/* NAV */}
      <nav className="fixed top-0 left-0 right-0 z-50 flex justify-between items-center px-10 py-5"
        style={{ background: 'rgba(0,0,0,0.25)', backdropFilter: 'blur(12px)' }}>
        <div className="w-8 h-8 rounded-full bg-white flex items-center justify-center">
          <div className="w-3.5 h-3.5 rounded-full bg-black" />
        </div>
        <div className="flex gap-10">
          {t.nav.map((n) => (
            <a key={n} href="#about" className="text-xs tracking-widest uppercase opacity-70 hover:opacity-100 transition-opacity">{n}</a>
          ))}
        </div>
        <div className="flex items-center gap-1">
          <button onClick={() => setLang('en')}
            className={`text-xs tracking-widest uppercase font-semibold px-2 py-1 rounded transition-colors ${lang === 'en' ? 'text-white bg-white/10' : 'text-white/35 hover:text-white/80'}`}>
            ENG
          </button>
          <button onClick={() => setLang('slo')}
            className={`text-xs tracking-widest uppercase font-semibold px-2 py-1 rounded transition-colors ${lang === 'slo' ? 'text-white bg-white/10' : 'text-white/35 hover:text-white/80'}`}>
            SLO
          </button>
          <span className="w-px h-4 bg-white/15 mx-3" />
          <a href="#contact" className="text-xs tracking-widest uppercase opacity-70 hover:opacity-100 transition-opacity">{t.connect}</a>
        </div>
      </nav>

      {/* HERO */}
      <div ref={heroRef} className="relative h-screen overflow-hidden">
        <canvas ref={canvasRef} className="absolute inset-0 w-full h-full bg-black" />
        <canvas ref={grainRef} className="absolute inset-0 w-full h-full pointer-events-none opacity-60"
          style={{ mixBlendMode: 'overlay' }} />

        <div className="absolute left-10 top-[42%] font-mono text-xs tracking-wide uppercase opacity-75 leading-7">
          {t.tagLeft.map((l, i) => <div key={i}>{l}</div>)}
        </div>
        <div className="absolute right-10 top-[42%] font-mono text-xs tracking-wide uppercase opacity-75 leading-7 text-right max-w-[180px]">
          {t.tagRight.map((l, i) => <div key={i}>{l}</div>)}
        </div>

        <div className="absolute bottom-[18%] left-0 right-0 text-center pointer-events-none">
          <div className="transition-opacity duration-300"
            style={{ fontFamily: "'Bebas Neue', sans-serif", fontSize: 'clamp(4rem,14vw,11rem)', lineHeight: 0.85, letterSpacing: '0.03em', textShadow: '0 0 80px rgba(255,255,255,.2)' }}>
            {t.heroText}
          </div>
        </div>

        <div className="absolute bottom-8 left-10 font-mono text-[10px] tracking-widest uppercase opacity-40">{t.credit}</div>
        <div className="absolute bottom-8 right-10 font-mono text-[10px] tracking-widest uppercase opacity-30">↓ scroll</div>
      </div>

      {/* ABOUT */}
      <div id="about" className="border-t border-white/10 bg-white/[0.015]">
        <section className="max-w-6xl mx-auto px-10 py-28">
          <div className="grid grid-cols-2 gap-24 items-start">
            <div>
              <h2 className="mb-8" style={{ fontFamily: "'Bebas Neue', sans-serif", fontSize: 'clamp(3rem,7vw,5rem)', letterSpacing: '0.05em' }}>
                {t.aboutTitle}
              </h2>
              <p className="text-base leading-8 opacity-70 max-w-md">{t.aboutText}</p>
            </div>
            <div className="pt-2">
              {t.skills.map((s) => (
                <div key={s} className="border-t border-white/10 py-5 flex justify-between items-center">
                  <span className="font-mono text-xs tracking-widest uppercase opacity-60">{s}</span>
                  <span className="opacity-20 text-sm">→</span>
                </div>
              ))}
              <div className="border-t border-white/10" />
            </div>
          </div>
        </section>
      </div>

      {/* CONTACT */}
      <div id="contact" className="border-t border-white/10">
        <section className="max-w-6xl mx-auto px-10 py-24 text-center">
          <h2 className="mb-10" style={{ fontFamily: "'Bebas Neue', sans-serif", fontSize: 'clamp(4rem,11vw,9rem)', letterSpacing: '0.02em', lineHeight: 0.9 }}>
            {t.contactTitle}
          </h2>
          <p className="text-sm opacity-50 mb-12">{t.contactText}</p>
          <a href="mailto:hello@example.com"
            className="inline-block border border-white/30 px-12 py-4 font-mono text-xs tracking-widest uppercase hover:bg-white/10 hover:border-white/60 transition-all">
            {t.contactBtn}
          </a>
        </section>
      </div>

      {/* FOOTER */}
      <footer className="border-t border-white/10 px-10 py-8 flex justify-between items-center">
        <span className="font-mono text-[10px] tracking-widest opacity-30">{t.copyright}</span>
        <div className="flex gap-8">
          {LINKS.map((l) =>
            l.url ? (
              <a key={l.label} href={l.url} target="_blank" rel="noopener noreferrer"
                className="text-xs tracking-widest uppercase opacity-35 hover:opacity-80 transition-opacity">
                {l.label}
              </a>
            ) : (
              <span key={l.label} className="text-xs tracking-widest uppercase opacity-35">{l.label}</span>
            )
          )}
        </div>
      </footer>
    </main>
  );
}
